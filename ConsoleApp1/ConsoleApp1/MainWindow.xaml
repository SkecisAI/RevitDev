<Window x:Class="RevitUpgradeController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revit Dialog Monitor"
        Height="680"
        Width="800"
        MinHeight="620"
        MinWidth="640">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Margin="0,0,10,8"
                   Text="Process Name:" />
        <TextBox x:Name="ProcessNameTextBox"
                 Grid.Row="0"
                 Grid.Column="1"
                 Margin="0,0,0,8"
                 Text="Revit" />

        <TextBlock Grid.Row="1"
                   Grid.ColumnSpan="2"
                   Foreground="Gray"
                   Margin="0,0,0,10"
                   Text="Monitor only running process, no auto start." />

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button x:Name="StartButton"
                    Width="90"
                    Height="30"
                    Margin="0,0,8,0"
                    Content="Start"
                    Click="StartButton_OnClick" />
            <Button x:Name="StopButton"
                    Width="90"
                    Height="30"
                    Margin="0,0,8,0"
                    Content="Stop"
                    IsEnabled="False"
                    Click="StopButton_OnClick" />
            <Button x:Name="CountButton"
                    Width="120"
                    Height="30"
                    Margin="0,0,8,0"
                    Content="Process Count"
                    Click="CountButton_OnClick" />
            <Button x:Name="ClearLogButton"
                    Width="120"
                    Height="30"
                    Content="Clear Log"
                    Click="ClearLogButton_OnClick" />
        </StackPanel>

        <GroupBox Grid.Row="3"
                  Grid.ColumnSpan="2"
                  Header="Keyword Config"
                  Margin="0,0,0,10">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,8,0">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="Dialog Keywords" />
                    <ListBox x:Name="DialogKeywordsListBox"
                             Height="100" />
                    <DockPanel Margin="0,6,0,0">
                        <Button Width="70"
                                Height="26"
                                Content="Add"
                                Click="AddDialogKeywordButton_OnClick"
                                DockPanel.Dock="Right" />
                        <TextBox x:Name="DialogKeywordInputTextBox"
                                 Margin="0,0,8,0" />
                    </DockPanel>
                    <Button Width="90"
                            Height="26"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Left"
                            Content="Remove"
                            Click="RemoveDialogKeywordButton_OnClick" />
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Margin="8,0,0,0">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="Button Priority" />
                    <ListBox x:Name="ButtonPriorityListBox"
                             Height="100" />
                    <DockPanel Margin="0,6,0,0">
                        <Button Width="70"
                                Height="26"
                                Content="Add"
                                Click="AddButtonKeywordButton_OnClick"
                                DockPanel.Dock="Right" />
                        <TextBox x:Name="ButtonKeywordInputTextBox"
                                 Margin="0,0,8,0" />
                    </DockPanel>
                    <Button Width="90"
                            Height="26"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Left"
                            Content="Remove"
                            Click="RemoveButtonKeywordButton_OnClick" />
                </StackPanel>

                <DockPanel Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Margin="0,10,0,0"
                           LastChildFill="True">
                    <Button Width="120"
                            Height="30"
                            Content="Reload Config"
                            Click="ReloadConfigButton_OnClick"
                            DockPanel.Dock="Right" />
                    <TextBlock Foreground="Gray"
                               VerticalAlignment="Center"
                               Text="Changes are auto-saved." />
                </DockPanel>
            </Grid>
        </GroupBox>

        <TextBox x:Name="LogTextBox"
                 Grid.Row="4"
                 Grid.ColumnSpan="2"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas" />
    </Grid>
</Window>
