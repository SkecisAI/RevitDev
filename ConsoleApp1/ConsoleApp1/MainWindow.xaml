<Window x:Class="RevitUpgradeController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revit Dialog Monitor"
        Height="500"
        Width="800"
        MinHeight="420"
        MinWidth="640">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Margin="0,0,10,8"
                   Text="Process Name:" />
        <TextBox x:Name="ProcessNameTextBox"
                 Grid.Row="0"
                 Grid.Column="1"
                 Margin="0,0,0,8"
                 Text="Revit" />

        <TextBlock Grid.Row="1"
                   Grid.ColumnSpan="2"
                   Foreground="Gray"
                   Margin="0,0,0,10"
                   Text="Monitor only running process, no auto start." />

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button x:Name="StartButton"
                    Width="90"
                    Height="30"
                    Margin="0,0,8,0"
                    Content="Start"
                    Click="StartButton_OnClick" />
            <Button x:Name="StopButton"
                    Width="90"
                    Height="30"
                    Content="Stop"
                    IsEnabled="False"
                    Click="StopButton_OnClick" />
        </StackPanel>

        <TextBox x:Name="LogTextBox"
                 Grid.Row="3"
                 Grid.ColumnSpan="2"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas" />
    </Grid>
</Window>
